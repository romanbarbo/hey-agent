{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hey-agent",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-10",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "TASK_AGENT",
				"class_name": "TaskAgent"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["TaskAgent"]
		}
	]
}
